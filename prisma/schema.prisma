
generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id        Int      @id @default(autoincrement())
  name      String
  company   String?
  phone     String?
  email     String
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}