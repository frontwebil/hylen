generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id        Int      @id @default(autoincrement())
  name      String
  company   String?
  phone     String?
  email     String
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductPageContent {
  slug      String   @id
  data      Json
  updatedAt DateTime @updatedAt
}

model HomepageCatalogItem {
  id         Int    @id @default(autoincrement())
  slug       String @unique
  titleUk    String
  titleEn    String
  subtitleUk String
  subtitleEn String
  imagePath  String
  sortOrder  Int    @default(0)
}
